{
  "name": "faker-typescript",
  "version": "1.0.0",
  "description": "TypeScript fake data generator (port of Python Faker)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dictionary": {
      "types": "./src/dictionary/index.ts",
      "default": "./src/dictionary/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  }
}